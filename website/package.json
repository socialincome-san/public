{
	"name": "@socialincome/website",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"serve": "npm run openapi:generate && npm run db:generate && next dev -p 3000",
		"serve:ssl": "npm run openapi:generate && npm run db:generate && next dev --experimental-https -p 3000",
		"build": "next build",
		"postbuild": "npm run openapi:generate && npm run copy-static-files",
		"prestart": "npm run db:migrate:deploy",
		"start": "npm-run-all -p start:emulators start:web",
		"start:emulators": "firebase emulators:start --only auth,storage --project demo-social-income-local --config ../firebase.json --import ../seed",
		"start:web": "PORT=3000 HOSTNAME=localhost node .next/standalone/website/server.js",
		"test:unit": "jest --forceExit --roots src/",
		"test:e2e": "playwright test",
		"test:e2e:update": "playwright test --update-snapshots",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --headed --debug",
		"test:e2e:verbose": "DEBUG=pw:webserver npm run test:e2e",
		"test:e2e:ui:verbose": "DEBUG=pw:webserver npm run test:e2e:ui",
		"copy-static-files": "cp -r public .next/standalone/website && cp -r .next/static .next/standalone/website/.next/",
		"emulator:start": "firebase emulators:start --project demo-social-income-local --only firestore,auth --config ../firebase.json --import ../seed",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"openapi:generate": "next-openapi-gen generate",
		"typecheck": "tsc --noEmit",
		"db:generate": "prisma generate",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:migrate:dev": "prisma migrate dev",
		"db:migrate:reset": "prisma migrate reset --force",
		"db:migrate:status": "prisma migrate status",
		"db:migrate:create": "prisma migrate dev --create-only",
		"db:introspect": "prisma db pull",
		"db:seed": "prisma db seed",
		"db:studio": "prisma studio",
		"db:up": "docker compose up -d postgres",
		"db:down": "docker compose down postgres",
		"check:unused": "knip --config knip.config.ts",
		"storyblok:login": "dotenv -e .env.local -- sh -c 'storyblok login --token $STORYBLOK_PERSONAL_ACCESS_TOKEN --region eu'",
		"storyblok:logout": "dotenv -e .env.local -- sh -c 'storyblok logout'",
		"storyblok:pull": "dotenv -e .env.local -- sh -c 'storyblok components pull --space $STORYBLOK_SPACE_ID --path src/generated/storyblok'",
		"storyblok:types": "dotenv -e .env.local -- sh -c 'storyblok types generate --space $STORYBLOK_SPACE_ID --path src/generated/storyblok'",
		"storyblok:generate": "npm run storyblok:login && npm run storyblok:pull && npm run storyblok:types"
	},
	"dependencies": {
		"@heroicons/react": "2.2.0",
		"@hookform/resolvers": "5.4.0",
		"@mux/mux-video-react": "0.31.0",
		"@prisma/adapter-pg": "7.8.0",
		"@prisma/client": "7.8.0",
		"@radix-ui/react-accordion": "1.2.13",
		"@radix-ui/react-avatar": "1.1.12",
		"@radix-ui/react-dialog": "1.1.16",
		"@radix-ui/react-dropdown-menu": "2.1.17",
